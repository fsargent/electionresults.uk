# ETL artefacts are CHECKED IN — they're the source of truth for the
# deployed site, so deploys (and CI/Cloudflare builds) skip the ETL
# step entirely. Re-run `bun run etl` locally when source data
# changes, then commit the regenerated artefacts.
#   /static/data/results.sqlite
#   /static/data/{cycles,councils,races,candidates}.csv
#   /src/lib/data/generated.json

.DS_Store
vite.config.*.timestamp-*

# Parliament ETL emits a per-run Markdown validation report (caveat
# counts, schema status, exclusions). Local-only artefact — useful for
# inspecting a data refresh, not for the deployed site.
_bmad-output/etl-reports/
